# Edmonton 3D Viewer — Environment Variables
#
# Copy to .env and fill in your values.

# Cloudflare R2 bucket for tree tile hosting
R2_BUCKET=your-bucket-name
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-key
R2_SECRET_ACCESS_KEY=your-secret

# Conversion service (optional, for model upload feature)
# Set this in the viewer URL as ?convertApi=https://your-tunnel.trycloudflare.com
CONVERT_API_PORT=5000
SKP_CONVERT_PORT=5001
