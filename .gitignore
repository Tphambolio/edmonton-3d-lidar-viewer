# ── LiDAR source data (~74GB) ────────────────────────────────────────────────
*.laz
*.las

# ── Generated mesh files ────────────────────────────────────────────────────
*.glb
*.dae
dae_export/
test_hawrelak/

# ── Cached building tiles (fetched from SODA API at runtime) ────────────────
edmonton-3d-viewer/data/building_tiles/

# ── Tree tile data (served from R2, not committed) ──────────────────────────
edmonton-3d-viewer/data/tree_tiles/*.glb
edmonton-3d-viewer/data/tree_tiles/*_tileset.json

# ── Conversion service runtime ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.wrangler/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
nohup.out

# ── Docker ──────────────────────────────────────────────────────────────────
.docker/

# ── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.code-workspace

# ── Environment / secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Temporary files ─────────────────────────────────────────────────────────
/tmp/
*.tmp

